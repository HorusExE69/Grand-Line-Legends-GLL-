    <!-- ════════════════════════════════════════════════════
         RELATIONS  — routage explicite sans croisement de boîtes
         Corridors libres utilisés :
           y = -60      (au-dessus de tous les blocs)
           y = 758      (entre Row1 max y=728 et Row2 min y=790)
           x = 1600     (entre col E max x=1560 et ctrl min x=1640)
           x = 1960     (entre ctrl max x=1940 et vue min x=2010)
           x = 1255     (gap 10 px entre col D max x=1250 et col E min x=1260)
         Styles :
           Composition  : startArrow=diamond;startFill=1 + endArrow=block;endFill=1
           Agrégation   : startArrow=diamond;startFill=0 + endArrow=block;endFill=0
           Association  : endArrow=block;endFill=1
           Dépendance   : dashed=1 + endArrow=block;endFill=1
    ════════════════════════════════════════════════════ -->

    <!-- ── MODELE  (connexions adjacentes, pas de croisement) ── -->

    <!-- Character ◆──* Capacity  (composition, horizontal direct) -->
    <mxCell id="e_chr_cap" value="1..*"
      style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;startArrow=diamond;startFill=1;endArrow=block;endFill=1;strokeColor=#1a1a1a;strokeWidth=3;endSize=12;startSize=12;fontStyle=1;fontSize=11;"
      edge="1" source="chr" target="cap" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Capacity ◇── Effect  (agrégation, horizontal direct) -->
