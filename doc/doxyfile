## doxyfile — Grand Line Legends
## Générer : make docu  (ou : doxygen doc/doxyfile depuis la racine)

#---------------------------------------------------------------------------
# Informations projet
#---------------------------------------------------------------------------
PROJECT_NAME           = "Grand Line Legends"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "RPG tour par tour One Piece — LIFAPCD, Université Lyon 1"
OUTPUT_DIRECTORY       = doc
OUTPUT_LANGUAGE        = French

#---------------------------------------------------------------------------
# Sources (chemins relatifs à la racine du projet)
#---------------------------------------------------------------------------
INPUT                  = src/model \
                         src/controller \
                         src/view
FILE_PATTERNS          = *.h *.cpp
RECURSIVE              = NO
EXCLUDE                = src/view/winTxt.h \
                         src/view/winTxt.cpp

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

#---------------------------------------------------------------------------
# Sortie HTML uniquement
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_TIMESTAMP         = YES
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Diagrammes (nécessite graphviz : sudo apt install graphviz)
#---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
CLASS_DIAGRAMS         = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 15
DOT_GRAPH_MAX_NODES    = 100

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
QUIET                  = NO
